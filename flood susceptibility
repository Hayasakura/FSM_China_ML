# Data Extraction Function
def extract(dbfroad, factor):
    # Extracts data, calculates Frequency Ratio (FR) for each indicator, 
    # then samples equal amounts of non-flood points to form the dataset XY_sample.
    # dbfroad: path to dbf file, factor: target columns to extract
    table = DBF(dbfroad, encoding='GBK')
    df = pd.DataFrame(iter(table))
    print("Data loaded successfully")
    XY = df.iloc[:, factor]  # Get all values from selected columns
    XY = np.array(XY.values)  # Convert variables to array
    column = XY.shape[1]  # Number of columns
    XY_max = np.max(XY, axis=0)  # Max value of each row
    max_val = np.max(XY_max)  # Global maximum value
    max_val = np.int64(max_val)
    
    # Counting (Classes count, and flood count within each class)
    num = np.zeros((max_val, column))  # Number of classes
    snum = np.zeros((max_val, column))  # Number of floods in class
    for a in range(column):  # Column loop
        for i in range(XY.shape[0]):  # Row loop
            for f in range(np.int64(XY_max[a])):  # Frequency Ratio rows
                if XY[i, a] == f + 1:  # Summing same class values
                    num[f, a] = num[f, a] + 1
                    if XY[i, -1] == 1:
                        snum[f, a] = snum[f, a] + 1

    # Frequency Ratio calculation
    num = num / XY.shape[0]  # Area ratio
    snum = snum / snum[0, -1]  # Flood area ratio
    pinglvbi = snum / num  # Frequency Ratio

    # Data assignment
    XY = XY.astype(float)  # Convert integer format to float for assignment
    for i in range(XY.shape[0]):
        for j in range(XY.shape[1] - 1):
            for a in range(max_val):
                if XY[i, j] == a + 1:
                    XY[i, j] = pinglvbi[a, j]  # Assign FR value

    # Sample Selection
    n_0 = 0  # Counter for non-flood
    n_1 = 0  # Counter for flood
    for i in range(XY.shape[0]):  # Count flood and non-flood points
        if XY[i, -1] == 0:
            n_0 = n_0 + 1
        elif XY[i, -1] == 1:
            n_1 = n_1 + 1
    s_0 = np.zeros(n_0)  # Index for non-flood
    q = 0  # Record non-flood count
    s_1 = np.zeros(n_1)  # Index for flood
    p = 0  # Record flood count
    for i in range(XY.shape[0]):  # Mark positions of flood/non-flood
        if XY[i, -1] == 0:
            s_0[q] = i
            q = q + 1
        elif XY[i, -1] == 1:
            s_1[p] = i
            p = p + 1

    XY_sample0 = np.zeros((q, XY.shape[1]))  # Non-flood samples
    XY_sample1 = np.zeros((p, XY.shape[1]))  # Flood samples

    for i in range(q):
        XY_sample0[i, :] = XY[int(s_0[i]), :]
    for i in range(p):
        XY_sample1[i, :] = XY[int(s_1[i]), :]
        
    if n_0 > n_1:
        random.seed(RANDOM_SEED)  # Fixed random seed
        XY_sample0 = random.sample(list(XY_sample0), n_1)
    else:
        random.seed(RANDOM_SEED)  # Fixed random seed
        XY_sample1 = random.sample(list(XY_sample1), n_0)

    XY_sample0 = np.array(XY_sample0)
    XY_sample1 = np.array(XY_sample1)
    XY_sample = tuple(XY_sample0) + tuple(XY_sample1)  # Merge flood and non-flood points
    XY_sample = np.array(XY_sample)

    try:
        if XY_sample.shape[1] - 1 > 0:
            print("\n=== Feature VIF Evaluation ===")
            vif_results = calculate_vif(XY_sample[:, :-1],
                                        feature_names if len(feature_names) == XY_sample.shape[1] - 1 else None)
            print(vif_results.to_string(index=False))

            vif_csv_path = os.path.join(os.path.dirname(yfxroad), "feature_vif_results.csv")
            vif_results.to_csv(vif_csv_path, index=False)
            print(f"VIF evaluation results saved to: {vif_csv_path}")
    except Exception as e:
        print(f"VIF calculation failed: {str(e)}")

    return XY_sample, XY

# Susceptibility Calculation Function
def yfx(XY_sample, XY):
    # Calculate flood susceptibility using seven built-in machine learning methods
    yifaxing = np.zeros((XY.shape[0], 7))
    data = XY_sample
    X_total = XY[:, 0:-1]
    X = data[:, :-1]
    y = data[:, -1]

    print(f"XY_sample count: {XY_sample.shape[0]}")
    print(f"XY total count: {XY.shape[0]}")

    # Split data into training and testing sets
    X_train, X_test, y_train, y_test = model_selection.train_test_split(X, y, test_size=0.3, random_state=RANDOM_SEED)

    # Create figure and canvas
    fig, ax = plt.subplots(dpi=300)
    canvas = FigureCanvasAgg(fig)

    # Collect AUC scores and predictions
    auc_scores = []
    model_names = ['SVC', 'RFC', 'KNC', 'CNN', 'GBDT', 'GNB', 'LR']
    all_predictions = {}  # Store predictions for each model

    # Support Vector Machine
    yifaxing[:, 0], auc, y_pred_svc = SVC(X_train, X_test, y_train, y_test, X_total, ax)
    auc_scores.append(auc)
    all_predictions['SVC'] = y_pred_svc

    # Random Forest
    yifaxing[:, 1], auc, y_pred_rfc = RFC(X_train, X_test, y_train, y_test, X_total, ax)
    auc_scores.append(auc)
    all_predictions['RFC'] = y_pred_rfc

    # K-Nearest Neighbors
    yifaxing[:, 2], auc, y_pred_knc = KNC(X_train, X_test, y_train, y_test, X_total, ax)
    auc_scores.append(auc)
    all_predictions['KNC'] = y_pred_knc

    # CNN Neural Network
    yifaxing[:, 3], auc, y_pred_cnn = CNN(X_train, X_test, y_train, y_test, X_total, ax)
    auc_scores.append(auc)
    all_predictions['CNN'] = y_pred_cnn

    # Gradient Boosting Decision Tree
    yifaxing[:, 4], auc, y_pred_gbdt = GBDT(X_train, X_test, y_train, y_test, X_total, ax)
    auc_scores.append(auc)
    all_predictions['GBDT'] = y_pred_gbdt

    # Gaussian Naive Bayes
    yifaxing[:, 5], auc, y_pred_gnb = GNB(X_train, X_test, y_train, y_test, X_total, ax)
    auc_scores.append(auc)
    all_predictions['GNB'] = y_pred_gnb

    # Logistic Regression
    yifaxing[:, 6], auc, y_pred_lr = LR(X_train, X_test, y_train, y_test, X_total, ax)
    auc_scores.append(auc)
    all_predictions['LR'] = y_pred_lr

    # Save AUC results
    save_auc_results(auc_scores, model_names)

    # Save classification metrics
    output_dir = os.path.dirname(yfxroad)
    for model_name in model_names:
        save_classification_metrics(y_test, all_predictions[model_name], model_name, output_dir)

    # Save final plot
    canvas.draw()
    file_path = os.path.join(os.path.dirname(yfxroad), "combined_ROC.png")
    canvas.print_png(file_path)
    plt.close()

    return yifaxing

# Support Vector Machine
def SVC(X_train, X_test, y_train, y_test, X_total, ax=None):
    # Train model
    svc = svm.SVC(probability=True)
    svc.fit(X=X_train, y=y_train)
    # Test model, ROC, AUC
    scores = svc.decision_function(X_test)
    fpr, tpr, thresholds = roc_curve(y_test, scores, pos_label=1)
    area = AUC(y_test, scores)
    ROC(fpr, tpr, area, "SVC", ax)
    name = "SVC"

    # Get predictions
    y_pred = svc.predict(X_test)

    # Add SHAP analysis
    save_weights_plot(svc, X_train, name)

    # Susceptibility mapping
    y_svc_hat_score = svc.decision_function(X=X_total)
    yifaxing_svc = 1 / (1 + np.exp(-y_svc_hat_score))
    return yifaxing_svc, area, y_pred

# Random Forest
def RFC(X_train , X_test, y_train, y_test, X_total, ax):
    # Train model
    rfc = RandomForestClassifier()
    rfc.fit(X_train, y_train)
    # Test model, ROC, AUC
    scores = rfc.predict_proba(X_test)[:, 1]
    fpr, tpr, thresholds = roc_curve(y_test, scores, pos_label=1)
    area = AUC(y_test, scores)
    name = "RFC"

    # Get predictions
    y_pred = rfc.predict(X_test)

    save_weights_plot(rfc, X_train, name)

    ROC(fpr, tpr, area, "RFC", ax)
    # Susceptibility mapping
    rfc_probs = rfc.predict_proba(X_total)
    yifaxing_rfc = rfc_probs[:, 1]
    return yifaxing_rfc, area, y_pred

