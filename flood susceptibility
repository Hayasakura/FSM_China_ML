# VIF calculation function
def calculate_vif(X, feature_names=None):
    """
    Calculate Variance Inflation Factor (VIF)
    :param X: Feature matrix (numpy array or pandas DataFrame)
    :param feature_names: Feature name list
    :return: DataFrame containing VIF values
    """
    if isinstance(X, np.ndarray):
        X = pd.DataFrame(X)

    # Add constant for VIF
    X_with_const = pd.DataFrame(X).copy()
    X_with_const['const'] = 1

    # Calculate VIF for each feature
    vif_data = pd.DataFrame()
    vif_data["feature"] = X.columns

    if feature_names is not None and len(feature_names) == X.shape[1]:
        vif_data["feature_name"] = feature_names
    vif_data["VIF"] = [variance_inflation_factor(X_with_const.values, i)
                       for i in range(X_with_const.shape[1] - 1)]  # Exclude constant

    return vif_data

