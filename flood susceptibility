# ROC plotting function
def ROC(fpr, tpr, area, name, ax=None):
    # If ax is not provided, create a new figure
    if ax is None:
        plt.figure()
        ax = plt.gca()

    # Plot ROC curve
    ax.plot(fpr, tpr, label=f'{name} (AUC = {area:.2f})')
    ax.plot([0, 1], [0, 1], color='black', linestyle='--')

    # Set plot attributes
    ax.set_xlim([-0.05, 1.05])
    ax.set_ylim([-0.05, 1.05])
    ax.set_xlabel('False Positive Rate (FPR)')
    ax.set_ylabel('True Positive Rate (TPR)')
    ax.legend(loc="lower right")

    # If called individually, save and show
    if ax is None:
        plt.savefig(os.path.join(os.path.dirname(yfxroad), f"{name}.jpg"))
        plt.show()

# Pairwise contribution function
def calculate_pairwise_contributions(shap_values, feature_names):
    num_features = len(feature_names)
    correlation_matrix = np.zeros((num_features, num_features))

    for i, j in itertools.combinations(range(num_features), 2):
        # Calculate pairwise SHAP correlation
        correlation = np.corrcoef(shap_values[:, i], shap_values[:, j])[0, 1]
        correlation_matrix[i, j] = correlation
        correlation_matrix[j, i] = correlation  # Symmetrical matrix

    # Fill diagonal with 1
    np.fill_diagonal(correlation_matrix, 1)

    return correlation_matrix

# Classification metrics function
def save_classification_metrics(y_true, y_pred, model_name, output_dir):
    """
    Calculate and save classification metrics to CSV
    """
    # Confusion matrix
    tn, fp, fn, tp = confusion_matrix(y_true, y_pred).ravel()

    # Metrics calculation
    accuracy = accuracy_score(y_true, y_pred)
    precision = precision_score(y_true, y_pred)
    recall = recall_score(y_true, y_pred)
    f1 = f1_score(y_true, y_pred)

    # Result dictionary
    metrics_data = {
        'Model': [model_name],
        'True_Negative': [tn],
        'False_Positive': [fp],
        'False_Negative': [fn],
        'True_Positive': [tp],
        'Accuracy': [accuracy],
        'Precision': [precision],
        'Recall': [recall],
        'F1_Score': [f1]
    }

    # DataFrame conversion
    metrics_df = pd.DataFrame(metrics_data)

    # Save to CSV
    csv_path = os.path.join(output_dir, f"{model_name}_classification_metrics.csv")
    metrics_df.to_csv(csv_path, index=False, float_format='%.4f')

    print(f"{model_name} metrics saved to: {csv_path}")

    return metrics_df

# SHAP summary plot and correlation function
def save_weights_plot(model, X_train, name, random_seed=1, n_clusters=200):
    import seaborn as sns
    import shap
    import numpy as np
    import pandas as pd
    import matplotlib.pyplot as plt
    import os
    import csv
    from matplotlib.colors import LinearSegmentedColormap
    from sklearn.utils import shuffle
    from matplotlib.collections import PathCollection

    # Use random sampling to reduce sample size
    if X_train.shape[0] > n_clusters:
        X_train_summary, _ = shuffle(
            X_train,
            np.zeros(X_train.shape[0]),
            n_samples=n_clusters,  # cluster count substitute
            random_state=random_seed
        )
    else:
        X_train_summary = X_train

    def predict_function(X):
        return model.predict_proba(X)[:, 1]

    # Create SHAP explainer
    explainer = shap.KernelExplainer(predict_function, X_train_summary)
    shap_values = explainer.shap_values(X_train_summary)

    # Average absolute SHAP values
    mean_abs_shap_values = np.mean(np.abs(shap_values), axis=0)

    # Normalization (Total 100%)
    mean_abs_shap_values_normalized = mean_abs_shap_values / np.sum(mean_abs_shap_values) * 100

    # Data for bar plot
    features = feature_names
    contributions = mean_abs_shap_values_normalized

    # Save contributions to CSV
    csv_path = os.path.join(os.path.dirname(yfxroad), f"{name}_shap_contributions.csv")
    with open(csv_path, mode='w', newline='') as file:
        writer = csv.writer(file)
        writer.writerow(["Feature", "Mean Absolute SHAP Value (%)"])
        for feature, shap_value in zip(features, contributions):
            writer.writerow([feature, shap_value])

    # =============================
    # Draw SHAP summary plot + Background bar + Top percentage axis + Legend
    # =============================
    fig, ax = plt.subplots(figsize=(8, 10), dpi=600)

    # Blue-Red colormap
    cmap = LinearSegmentedColormap.from_list("blue_red", ["#0000FF", "#FF0000"])

    # summary_plot dot plot
    shap.summary_plot(
        shap_values,
        pd.DataFrame(X_train_summary, columns=features),
        plot_type="dot",
        cmap=cmap,
        show=False
    )

    # collection scatter point size
    point_size = 60
    for collection in ax.collections:
        if isinstance(collection, PathCollection):
            current_sizes = collection.get_sizes()
            if len(current_sizes) > 0:
                collection.set_sizes([point_size] * len(current_sizes))

    # Y-axis feature order
    shap_df = pd.DataFrame(shap_values, columns=features)
    yticks = ax.get_yticks()
    ylabels = [tick.get_text() for tick in ax.get_yticklabels()]

    # X-axis range
    x_min, x_max = ax.get_xlim()
    x_range = x_max - x_min

    # Background contribution bars
    for y, feature in zip(yticks, ylabels):
        if feature in features:
            idx = features.index(feature)
            contrib = contributions[idx]
            bar_percentage = min(contrib, 60)
            bar_width = (bar_percentage / 60) * x_range
            ax.barh(y, bar_width, height=0.5, alpha=0.4,
                    color='steelblue', left=x_min, zorder=1)

    # =============================
    # Median dot + Std line
    # =============================
    stats_data = [] 
    for y, feature in zip(yticks, ylabels):
        if feature in shap_df.columns:
            vals = shap_df[feature].values
            median_val = np.median(vals)
            std_val = np.std(vals)
            stats_data.append([feature, median_val, std_val])

            # Median marker (RGB: 252,192,12)
            ax.plot(median_val, y,
                    marker='s',
                    color=(252/255, 192/255, 12/255),
                    markersize=9,
                    zorder=5,
                    label='Median' if y == yticks[0] else "")
            # Std Dev dashed line (RGB: 252,192,12, Width: 2.88)
            ax.hlines(y, median_val - std_val, median_val + std_val,
                      colors=[(252/255, 192/255, 12/255)],
                      linewidth=2.88, linestyle='--', zorder=4,
                      label='±1 Std Dev' if y == yticks[0] else "")

    # Export stats to CSV
    stats_csv_path = os.path.join(os.path.dirname(yfxroad), f"{name}_shap_stats.csv")
    with open(stats_csv_path, mode='w', newline='') as file:
        writer = csv.writer(file)
        writer.writerow(["Feature", "Median", "StdDev"])
        for row in stats_data:
            writer.writerow(row)

    # Legend
    ax.legend(loc='lower right', fontsize=8)

    # Top percentage axis
    ax_top = ax.secondary_xaxis('top')
    ax_top.set_xlabel('Variable Importance %', fontsize=9)
    max_percentage = 60
    percent_ticks = np.linspace(x_min, x_max, 11)
    percent_labels = [f'{(x - x_min) / x_range * max_percentage:.0f}' for x in percent_ticks]
    ax_top.set_xticks(percent_ticks)
    ax_top.set_xticklabels(percent_labels, fontsize=7)

    plt.title(f"{name} SHAP Summary Plot", fontsize=16)
    plt.tight_layout()
    plt.savefig(os.path.join(os.path.dirname(yfxroad), f"{name}_shap_summary_plot.jpg"))
    plt.show()

    # =============================
    # Correlation Heatmap
    # =============================
    fig_heatmap, ax_heatmap = plt.subplots(figsize=(6.67, 5.33), dpi=600)

    # Correlation matrix
    corr_matrix = np.corrcoef(X_train_summary.T)

    # Create heatmap
    sns.heatmap(
        corr_matrix,
        xticklabels=features,
        yticklabels=features,
        cmap='RdBu_r',
        center=0,
        annot=True,
        fmt='.2f',
        square=True,
        cbar_kws={'label': 'Correlation Coefficient', 'shrink': 1.0},
        annot_kws={'size': 6},
        ax=ax_heatmap,
        vmin=-1,
        vmax=1
    )

    ax_heatmap.set_title(f'{name} Feature Correlation Heatmap', fontsize=18)
    ax_heatmap.set_xticklabels(ax_heatmap.get_xticklabels(), rotation=45, ha='right', fontsize=12)
    ax_heatmap.set_yticklabels(ax_heatmap.get_yticklabels(), rotation=0, fontsize=12)

    plt.tight_layout()

    # Save heatmap
    plt.savefig(os.path.join(os.path.dirname(yfxroad), f"{name}_feature_correlation_heatmap.jpg"))
    plt.show()

    print(f"All plots and CSVs saved for {name}")


